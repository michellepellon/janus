# ABOUTME: Template for local credentials — copy to .env and fill in.
# ABOUTME: .env is gitignored; never commit real credentials.

# SensorPush Gateway Cloud account (same login as the mobile app)
SENSORPUSH_USERNAME=you@example.com
SENSORPUSH_PASSWORD=your-password

# Outside-air pseudo-sensor: an NWS observation station ID (see
# https://www.weather.gov/documentation/services-web-api). Comment out or
# remove to disable outside collection.
JANUS_OUTSIDE_STATION=KEFD

# Optional overrides (defaults shown)
# JANUS_DB_PATH=data/janus.duckdb
# JANUS_PORT=8367
# JANUS_POLL_SECONDS=300
# User-Agent sent to the NWS API (it rejects unidentified requests); include
# contact info if you want, e.g. "janus-dashboard (you@example.com)"
# JANUS_NWS_USER_AGENT=janus-dashboard

# Philips Hue bridge credentials — written by bin/hue-pair (see README
# "Lights & outlets"). Remove both to disable Hue collection.
# HUE_BRIDGE_IP=192.168.1.50
# HUE_APP_KEY=your-app-key
